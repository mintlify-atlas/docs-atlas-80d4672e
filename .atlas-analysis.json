  "keyFeatures": [
    "AI-powered resume parsing and ATS scoring using GPT-4o-mini",
    "Semantic job-resume matching with pgvector/Pinecone embeddings",
    "Full hiring pipeline with kanban board and stage tracking",
    "KAREN — an AI career coaching agent for job seekers and recruiters",
    "Premium resume optimizer with JD-tailored bullet rewriting",
    "Benchmark comparison against selected candidate pool",
    "Real-time pipeline notifications via SendGrid",
    "Transparent ATS reports showing exactly why a resume passes or fails",
    "Insider referral network for warm introductions",
    "Salary insights aggregated from job postings"
  ],
  "publicApiSurface": [
    "POST /api/v1/auth/register",
    "POST /api/v1/auth/login",
    "POST /api/v1/resume/upload",
    "GET /api/v1/resume/me",
